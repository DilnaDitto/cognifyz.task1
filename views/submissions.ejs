<!-- views/submissions.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stored Users</title>
</head>
<body style="font-family: Arial, sans-serif; padding: 40px; background-color: #f8f9fa;">
    <div style="max-width: 600px; margin: 0 auto; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
        <h2>Registered Users (Temporary Storage)</h2>
        
        <!-- EJS Conditional rendering -->
        <% if (users.length === 0) { %>
            <p style="color: #777;">No users registered yet.</p>
        <% } else { %>
            <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
                <thead>
                    <tr style="background-color: #007bff; color: white; text-align: left;">
                        <th style="padding: 10px;">Name</th>
                        <th style="padding: 10px;">Email</th>
                        <th style="padding: 10px;">Age</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Loop through the array passed from server.js -->
                    <% users.forEach(user => { %>
                        <tr style="border-bottom: 1px solid #ddd;">
                            <td style="padding: 10px;"><%= user.name %></td>
                            <td style="padding: 10px;"><%= user.email %></td>
                            <td style="padding: 10px;"><%= user.age %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
        
        <br><br>
        <a href="/task2" style="padding: 10px 15px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 5px;">Back to Form</a>
    </div>
</body>
</html>