<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task 4: Dynamic DOM & Routing</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #121212; color: #ffffff; }
        .view-section { display: none; /* Hidden by default, JS will reveal them */ }
        .view-section.active { display: block; animation: fadeIn 0.4s ease-in; }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .custom-card { background-color: #1e1e1e; border: 1px solid #333; }
        .nav-link { color: #aaa !important; cursor: pointer; }
        .nav-link:hover, .nav-link.active-tab { color: #0d6efd !important; font-weight: bold; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
        <div class="container">
            <a class="navbar-brand" href="#dashboard">SecureApp</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link nav-tab" href="#dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link nav-tab" href="#register">Register</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        
        <div id="dashboard" class="view-section">
            <h2>Welcome to the Dashboard</h2>
            <p class="text-secondary">This page loaded instantly via Client-Side Routing. No server refresh required!</p>
            <a href="#register" class="btn btn-outline-primary mt-3">Go to Registration</a>
        </div>

        <div id="register" class="view-section">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="card custom-card p-4 shadow-lg text-light">
                        <h3 class="mb-4">Create Secure Account</h3>
                        
                        <form id="secureForm">
                            <div class="mb-3">
                                <label class="form-label">Username</label>
                                <input type="text" class="form-control bg-dark text-light border-secondary" required>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" id="passwordInput" class="form-control bg-dark text-light border-secondary" placeholder="Enter password">
                                
                                <div class="mt-2 text-end fw-bold" id="strengthText" style="font-size: 0.85rem;"></div>
                                <div class="progress mt-1" style="height: 5px; background-color: #333;">
                                    <div id="strengthMeter" class="progress-bar" role="progressbar" style="width: 0%;"></div>
                                </div>
                                <ul class="text-secondary mt-2" style="font-size: 0.85rem;">
                                    <li id="req-len">8+ characters</li>
                                    <li id="req-up">1 Uppercase letter</li>
                                    <li id="req-num">1 Number</li>
                                    <li id="req-sp">1 Special character (@, $, !, etc.)</li>
                                </ul>
                            </div>

                            <button type="button" class="btn btn-primary w-100">Sign Up</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script>
        // ----------------------------------------------------
        // 1. CLIENT-SIDE ROUTING LOGIC
        // ----------------------------------------------------
        function handleRouting() {
            // Get the hash from the URL (e.g., "#register"). Default to "#dashboard"
            const hash = window.location.hash || '#dashboard';
            
            // Hide all sections
            document.querySelectorAll('.view-section').forEach(section => {
                section.classList.remove('active');
            });
            
            // Update Navigation Highlighting
            document.querySelectorAll('.nav-tab').forEach(tab => {
                tab.classList.remove('active-tab');
                if(tab.getAttribute('href') === hash) tab.classList.add('active-tab');
            });

            // Show the requested section (Dynamic DOM Update)
            const targetSection = document.querySelector(hash);
            if (targetSection) targetSection.classList.add('active');
        }

        // Listen for changes in the URL hash (when user clicks links or uses back button)
        window.addEventListener('hashchange', handleRouting);
        // Run once when the page initially loads
        window.addEventListener('load', handleRouting);


        // ----------------------------------------------------
        // 2. COMPLEX FORM VALIDATION & DYNAMIC DOM (Password)
        // ----------------------------------------------------
        const passwordInput = document.getElementById('passwordInput');
        const strengthMeter = document.getElementById('strengthMeter');
        const strengthText = document.getElementById('strengthText');

        // Listen to every single keystroke in the password field
        passwordInput.addEventListener('input', function(e) {
            const val = e.target.value;
            let score = 0;

            // Regex Validation Checks
            const hasLength = val.length >= 8;
            const hasUpper = /[A-Z]/.test(val);
            const hasNumber = /[0-9]/.test(val);
            const hasSpecial = /[^A-Za-z0-9]/.test(val);

            // Dynamic DOM styling for requirements list
            document.getElementById('req-len').style.color = hasLength ? '#198754' : '#6c757d';
            document.getElementById('req-up').style.color = hasUpper ? '#198754' : '#6c757d';
            document.getElementById('req-num').style.color = hasNumber ? '#198754' : '#6c757d';
            document.getElementById('req-sp').style.color = hasSpecial ? '#198754' : '#6c757d';

            // Calculate Score
            if (hasLength) score++;
            if (hasUpper) score++;
            if (hasNumber) score++;
            if (hasSpecial) score++;

            // Update Progress Bar DOM based on score
            if (val.length === 0) {
                strengthMeter.style.width = '0%';
                strengthText.innerText = '';
            } else if (score <= 2) {
                strengthMeter.style.width = '33%';
                strengthMeter.className = 'progress-bar bg-danger';
                strengthText.innerText = 'Weak';
                strengthText.style.color = '#dc3545';
            } else if (score === 3) {
                strengthMeter.style.width = '66%';
                strengthMeter.className = 'progress-bar bg-warning';
                strengthText.innerText = 'Medium';
                strengthText.style.color = '#ffc107';
            } else if (score === 4) {
                strengthMeter.style.width = '100%';
                strengthMeter.className = 'progress-bar bg-success';
                strengthText.innerText = 'Strong';
                strengthText.style.color = '#198754';
            }
        });
    </script>
</body>
</html>